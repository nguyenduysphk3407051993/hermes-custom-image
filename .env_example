# Domain config
DOMAIN_NAME=edutechnd.io.vn
SUBDOMAIN=hermes
DASHBOARD_SUBDOMAIN=hermes-dash

# Dashboard basic auth — tạo bằng htpasswd (echo $(htpasswd -nb admin hermes-edutechnd-io-vn) | sed -e s/\\$/\\$\\$/g)
DASHBOARD_AUTH=admin:$$apr1$$replace_with_generated_hash

# Hermes API server key (chỉ cần nếu bật API_SERVER_ENABLED)(openssl rand -hex 32)
API_SERVER_KEY=replace_with_random_key
